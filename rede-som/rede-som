import numpy as np
import pandas as pd
from sklearn.datasets import load_wine
from sklearn.preprocessing import MinMaxScaler
from sklearn.decomposition import PCA
from sklearn.cluster import KMeans
from minisom import MiniSom
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.metrics import silhouette_score

# =========================
# 1. Dataset
# =========================
data = load_wine()
X = data.data
y = data.target

# =========================
# 2. Normalização
# =========================
scaler = MinMaxScaler()
X_scaled = scaler.fit_transform(X)

# =========================
# 3. SOM
# =========================
som = MiniSom(
    x=12, y=12,
    input_len=X.shape[1],
    sigma=1.2,
    learning_rate=0.4,
    random_seed=42
)

som.random_weights_init(X_scaled)
som.train_random(X_scaled, 2000)

# =========================
# 4. Extração de winners (neurônios vencedores)
# =========================
winners = np.array([som.winner(x) for x in X_scaled])
winners_2d = np.array([w[0]*12 + w[1] for w in winners])

# =========================
# 5. KMeans em cima do SOM
# =========================
kmeans = KMeans(n_clusters=3, random_state=42)
clusters = kmeans.fit_predict(winners_2d.reshape(-1, 1))

# =========================
# 6. PCA para comparação
# =========================
pca = PCA(n_components=2)
X_pca = pca.fit_transform(X_scaled)

# =========================
# 7. VISUALIZAÇÃO SOM + CLUSTERS
# =========================
plt.figure(figsize=(8,6))
plt.title("Clusters baseados em SOM + KMeans")

sns.scatterplot(
    x=winners[:,0],
    y=winners[:,1],
    hue=clusters,
    palette="Set1",
    s=80
)

plt.xlabel("SOM X")
plt.ylabel("SOM Y")
plt.legend()
plt.show()

# =========================
# 8. VISUALIZAÇÃO PCA (comparação)
# =========================
plt.figure(figsize=(8,6))
plt.title("PCA (comparação com SOM)")

sns.scatterplot(
    x=X_pca[:,0],
    y=X_pca[:,1],
    hue=y,
    palette="Set1",
    s=80
)

plt.xlabel("PC1")
plt.ylabel("PC2")
plt.show()

def avaliar_clusters(X, labels):
    score = silhouette_score(X, labels)
    print(f"Silhouette Score: {score:.4f}")
    return score

avaliar_clusters(winners_2d.reshape(-1,1), clusters)

plt.figure(figsize=(7,6))
plt.title("U-Matrix - SOM")

u_matrix = som.distance_map().T
plt.pcolor(u_matrix, cmap='coolwarm')
plt.colorbar()
plt.show()

df = pd.DataFrame(X_scaled, columns=data.feature_names)
df["cluster"] = clusters

print(df.groupby("cluster").mean())

